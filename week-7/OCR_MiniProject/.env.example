# --- Runtime ---
APP_ENV=development

# --- Database (SQLite by default; swap to postgresql+psycopg for prod) ---
DATABASE_URL=sqlite:///./data/portal.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# --- Uploads ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=10

# --- OCR ---
OCR_CONFIDENCE_THRESHOLD=0.6
TROCR_MODEL=microsoft/trocr-base-handwritten

# --- Verification ---
VERIFICATION_MIN_CONFIDENCE=0.6

# --- Gradio UI ---
GRADIO_API_URL=http://127.0.0.1:8000
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860
GRADIO_SHARE=false

# --- Preprocessing ---
PREPROCESS_MAX_DIM=1600
PREPROCESS_DESKEW=true
PREPROCESS_BINARIZE=false

# --- PaddleOCR (Phase 6) ---
PADDLEOCR_LANG=en
PADDLEOCR_USE_ANGLE_CLS=true
PADDLEOCR_NOTEBOOK=notebooks/paddleocr_engine.ipynb
